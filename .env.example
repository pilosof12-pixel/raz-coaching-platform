# Copy this file to `.env` for local use, OR set these in Render's
# Environment tab. NEVER commit your real key.

# Your Google AI Studio key (https://aistudio.google.com -> Get API key)
GEMINI_API_KEY=your-key-here

# Model (default is gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Port — Render sets this automatically; leave unset in production.
# PORT=8000

# Optional rate limits per client token per day
# DAILY_BUILDS=2
# DAILY_ADJUSTS=8

# LOCAL DEV ONLY — do not set in production:
# USE_PPLX_PROXY=1
